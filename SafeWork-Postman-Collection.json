        },
        {
          "name": "Get Employee Document",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{gateway}}/employees/1/document"
          }
        },
        {
          "name": "Report Hazard (EMPLOYEE only)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{gateway}}/employees/hazard/report",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hazardType\": \"Chemical Spill\",\n  \"hazardDescription\": \"Chemical spill in lab section B\",\n  \"hazardLocation\": \"Lab Section B\",\n  \"hazardDate\": \"2026-04-11\",\n  \"employeeId\": 1\n}"
            }
          }
        }
      ]
    },
