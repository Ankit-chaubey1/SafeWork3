{
  "info": {
    "name": "SafeWork – Occupational Safety API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for SafeWork microservices. All protected requests use the {{token}} variable set automatically on login."
  },
  "variable": [
    { "key": "gateway", "value": "http://localhost:8091", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. User Service – Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Admin User\",\n  \"userEmail\": \"admin@safework.com\",\n  \"userContact\": \"9876543210\",\n  \"userStatus\": \"ACTIVE\",\n  \"password\": \"admin123\",\n  \"userRole\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Register Compliance Officer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Compliance Officer\",\n  \"userEmail\": \"compliance@safework.com\",\n  \"userContact\": \"9876543211\",\n  \"userStatus\": \"ACTIVE\",\n  \"password\": \"comp123\",\n  \"userRole\": \"COMPLIANCE_OFFICER\"\n}"
            }
          }
        },
        {
          "name": "Register Safety Officer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Safety Officer\",\n  \"userEmail\": \"safety@safework.com\",\n  \"userContact\": \"9876543212\",\n  \"userStatus\": \"ACTIVE\",\n  \"password\": \"safety123\",\n  \"userRole\": \"SAFETY_OFFICER\"\n}"
            }
          }
        },
        {
          "name": "Register Hazard Officer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Hazard Officer\",\n  \"userEmail\": \"hazard@safework.com\",\n  \"userContact\": \"9876543213\",\n  \"userStatus\": \"ACTIVE\",\n  \"password\": \"hazard123\",\n  \"userRole\": \"HAZARD_OFFICER\"\n}"
            }
          }
        },
        {
          "name": "Login as Admin → sets {{token}}",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                "pm.test('Login successful', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@safework.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login as Employee → sets {{token}}",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                "pm.test('Login successful', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@safework.com\",\n  \"password\": \"emp123\"\n}"
            }
          }
        },
        {
          "name": "Login as Compliance Officer → sets {{token}}",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                "pm.test('Login successful', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"compliance@safework.com\",\n  \"password\": \"comp123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Employee Service",
      "item": [
        {
          "name": "Register Employee (public)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{gateway}}/employees/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@safework.com\",\n  \"password\": \"emp123\",\n  \"employeeName\": \"John Doe\",\n  \"employeeDOB\": \"1995-06-15\",\n  \"employeeGender\": \"Male\",\n  \"employeeAddress\": \"123 Main Street, Chennai\",\n  \"employeeContact\": \"9876543200\",\n  \"employeeDepartmentName\": \"Operations\",\n  \"employeeStatus\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Get All Employees (ADMIN only)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{gateway}}/employees/getall"
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{gateway}}/employees/1"
          }
        },
        {
          "name": "Get Employee Hazards",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{gateway}}/employees/1/hazards"
